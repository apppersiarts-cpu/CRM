# Vercel Blob Storage Token
# Get this from your Vercel project dashboard under Storage > Blob
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres Configuration
# These are automatically provided by Vercel when you link a Postgres database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
